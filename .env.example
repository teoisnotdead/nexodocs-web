# NexoDocs Web production environment
# Configure these in Vercel.

# Public API URL.
# This value is exposed to the browser bundle by Next.js.
NEXT_PUBLIC_API_URL=https://your-nexodocs-api.onrender.com

# Server-only API URL used by Next.js route handlers and server components.
# Usually the same Render URL in production.
API_INTERNAL_URL=https://your-nexodocs-api.onrender.com
